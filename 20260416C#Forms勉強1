```MainForm.cs
using System;
using System.Drawing;
using System.Windows.Forms;

namespace ButtonApp
{
    public class MainForm : Form
    {
        private Button myButton;
        private int clickCount = 0;
        
        public MainForm()
        {
            // Window属性
            this.Text = "Window左上の名称";
            this.Size = new Size(400, 300);
            this.StartPosition = FormStartPosition.CenterScreen;//起動時にWindowを表示する位置
            
            // ボタン
            myButton = new Button();
            myButton.Text = "押下";
            myButton.Size = new Size(100, 50);
            myButton.Location = new Point(150, 100);
            
            // 押下時の処理
            myButton.Click += (sender, e) =>
            {
                clickCount++;
                myButton.Text = $"{clickCount}回";
                
                MessageBox.Show($" {clickCount} 回押下", "回数", 
                    MessageBoxButtons.OK, MessageBoxIcon.Information);
            };
            
            // ボタンをWindowへ追加
            this.Controls.Add(myButton);
        }
    }
}
```


